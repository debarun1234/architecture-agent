# Copy this file to .env and fill in your values
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the ChromaDB persistence directory
CHROMA_DB_PATH=./backend/knowledge_base/chroma_db

# Optional: Gemini model to use (legacy steps)
GEMINI_MODEL=gemini-3.1-flash-lite
# ADK pipeline model (used by the 6-step architecture review agent)
ADK_MODEL=gemini-3.1-flash-lite

# Jira configuration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_ORG_ID=your-jira-org-id
JIRA_USER_EMAIL=your_atlassian_email@example.com
JIRA_API_TOKEN=your_jira_api_token

# Jira project key to monitor (e.g. ARCH, PLAT) — required for auto-polling
JIRA_PROJECT_KEY=your_project_key

# Optional: only process stories under this epic key
# Leave blank to monitor all stories in the project
JIRA_EPIC_KEY=

# How often to poll Jira for new stories / comments (seconds, default 60)
JIRA_POLL_INTERVAL=60

# Optional: Jira workflow transition IDs (override if your project differs)
JIRA_TRANSITION_TO_DO=11
JIRA_TRANSITION_IN_PROGRESS=21
JIRA_TRANSITION_IN_REVIEW=31
JIRA_TRANSITION_DONE=41
